<div class="border-2 border-black bg-[#FAFAF8] p-8 mb-8">
  <form class="space-y-6">
    <div>
      <label for="url-input" class="block text-xs font-mono uppercase tracking-widest text-black mb-3 font-bold">
        <span class="bg-[#E8F4F8] px-2 py-1">Wklej URL</span>
      </label>
      <input
        type="url"
        id="url-input"
        placeholder="https://www.twoja-strona.pl/z-bardzo-dlugim-linkiem"
        class="w-full px-4 py-4 border-2 border-black focus:outline-none focus:border-black focus:ring-2 focus:ring-[#E8F4F8] text-black font-mono bg-[#FAFAF8] placeholder-gray-400"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-black text-[#FAFAF8] font-mono uppercase tracking-widest py-4 px-6 border-2 border-black hover:bg-[#E8F4F8] hover:text-black transition-colors duration-100 font-bold text-sm hover:cursor-pointer"
    >
      [ linkuj ]
    </button>
  </form>
</div>
