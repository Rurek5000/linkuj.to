<div
  id="result-section"
  class="hidden flex-col gap-6 border-2 border-black bg-[#FAFAF8] p-8"
>
  <div class="flex flex-col gap-3">
    <div
      class="font-mono text-xs font-bold tracking-widest text-black uppercase"
    >
      <span class="bg-[#E8F4F8] px-2 py-1">Gotowe</span>
    </div>
    <div class="border border-black bg-[#F5F5F3] p-4 font-mono text-sm">
      <span class="text-black">01:</span>
      <span class="ml-2 text-black">Udało się skrócić twój link!</span>
    </div>
  </div>

  <div class="flex items-stretch">
    <input
      id="short-url-input"
      type="text"
      readonly
      class="h-[60px] flex-1 border-2 border-black bg-black px-4 font-mono text-[#FAFAF8] focus:outline-none"
    />
    <button
      id="copy-btn"
      type="button"
      aria-label="Kopiuj link"
      class="flex h-[60px] items-center justify-center border-2 border-l-0 border-black bg-[#FAFAF8] px-4 text-black transition-colors duration-100 hover:cursor-pointer hover:bg-[#E8F4F8]"
    >
      <svg
        id="copy-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="square"
        stroke-linejoin="miter"
      >
        <rect x="9" y="9" width="13" height="13" rx="0" ry="0"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
        ></path>
      </svg>
      <svg
        id="check-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="square"
        stroke-linejoin="miter"
        class="hidden"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </button>
  </div>

  <button
    id="shorten-another"
    type="button"
    class="h-[60px] border-2 border-black bg-[#FAFAF8] px-4 font-mono text-sm font-bold tracking-widest text-black uppercase transition-colors duration-100 hover:cursor-pointer hover:bg-[#E8F4F8]"
  >
    [ skróć kolejny ]
  </button>
</div>
