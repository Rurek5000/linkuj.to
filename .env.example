# ============================================
# URL Shortener - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- Required for production ---

# Google Safe Browsing API (blocks malicious URLs)
# Get key: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

# Cloudflare Turnstile (bot protection)
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
CLOUDFLARE_TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

# --- Optional (have defaults in docker-compose) ---

# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/shortener
# REDIS_URL=redis://localhost:6379
# BASE_URL=http://localhost:3002
# NODE_ENV=development
